@model FoodOrderManagementSystem.Models.Product
@{
    var isNew = Model.ProductId == 0;
    ViewData["Title"] = isNew ? "Yeni Ürün" : "Ürün Düzenle";
    ViewData["Breadcrumb"] = $"Yönetim / Ürünler / {(isNew ? "Yeni" : "Düzenle")}";
}

<div class="page-header">
    <div>
        <h1>@ViewData["Title"]</h1>
        <p>@(isNew ? "Menüye yeni bir ürün ekleyin" : $"#{Model.ProductId} — {Model.ProductName}")</p>
    </div>
    <a href="/Product/List" class="btn btn-secondary">← Listeye Dön</a>
</div>

<div class="card" style="max-width:480px;">
    <div class="card-header">
        <span class="card-title">@(isNew ? "Ürün Bilgileri" : "Bilgileri Güncelle")</span>
    </div>
    <div class="card-body">
        <form action="/Product/Save" method="post">
            <div class="form-grid">
                <input type="hidden" name="ProductId" value="@Model.ProductId" />

                <div class="form-group">
                    <label class="form-label">Ürün Adı</label>
                    <input class="form-control"
                           type="text"
                           name="ProductName"
                           value="@Model.ProductName"
                           placeholder="örn. Karışık Pizza"
                           required />
                </div>

                <div class="form-group">
                    <label class="form-label">Fiyat (₺)</label>
                    <input class="form-control"
                           type="number"
                           step="0.01"
                           name="Price"
                           value="@Model.Price"
                           placeholder="0.00"
                           required />
                </div>

                <div class="divider"></div>

                <div style="display:flex; gap:10px; justify-content:flex-end;">
                    <a href="/Product/List" class="btn btn-secondary">İptal</a>
                    <button type="submit" class="btn btn-primary">
                        @(isNew ? "✅ Ürün Ekle" : "💾 Değişiklikleri Kaydet")
                    </button>
                </div>
            </div>
        </form>
    </div>
</div>