@model IEnumerable<FoodOrderManagementSystem.Models.Order>
@{
    ViewData["Title"] = "Siparişler";
    ViewData["Breadcrumb"] = "Yönetim / Siparişler";
    var users = ViewBag.Users as Dictionary<int, string> ?? new Dictionary<int, string>();
}

<div class="page-header">
    <div>
        <h1>Siparişler</h1>
        <p>Tüm siparişleri görüntüle ve yönet</p>
    </div>
    <a asp-controller="Order" asp-action="Edit" class="btn btn-primary">
        + Yeni Sipariş
    </a>
</div>

<div class="stats-row">
    <div class="stat-card">
        <div class="stat-icon">📋</div>
        <div class="stat-label">Toplam Sipariş</div>
        <div class="stat-value">@Model.Count()</div>
    </div>
    <div class="stat-card">
        <div class="stat-icon">💰</div>
        <div class="stat-label">Toplam Ciro</div>
        <div class="stat-value" style="color:var(--accent);">
            ₺@Model.Sum(o => o.TotalAmount).ToString("N0")
        </div>
    </div>
</div>

<div class="card">
    <div class="card-header">
        <span class="card-title">Sipariş Listesi</span>
        <span style="font-size:13px; color:var(--muted);">@Model.Count() sipariş</span>
    </div>
    <div class="table-wrap">
        @if (!Model.Any())
        {
            <div class="empty-state">
                <div class="empty-icon">📭</div>
                <h3>Henüz sipariş yok</h3>
                <p>Yeni sipariş oluşturmak için yukarıdaki butonu kullanın.</p>
                <a asp-controller="Order" asp-action="Edit" class="btn btn-primary">+ Yeni Sipariş</a>
            </div>
        }
        else
        {
            <table>
                <thead>
                    <tr>
                        <th>Sipariş No</th>
                        <th>Müşteri</th>
                        <th>Tarih</th>
                        <th>Tutar</th>
                        <th>İşlemler</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var order in Model)
                    {
                        var customerName = users.ContainsKey(order.UserId) ? users[order.UserId] : $"Kullanıcı #{order.UserId}";
                        <tr>
                            <td style="font-weight:600; color:var(--accent);">
                                #@order.OrderId
                            </td>
                            <td style="font-weight:500;">
                                @customerName
                            </td>
                            <td style="color:var(--muted);">
                                @order.OrderDate.ToString("dd MMM yyyy")
                                <div style="font-size:12px;">@order.OrderDate.ToString("HH:mm")</div>
                            </td>
                            <td style="font-weight:700; color:var(--accent);">
                                ₺@order.TotalAmount.ToString("N2")
                            </td>
                            <td>
                                <div style="display:flex; gap:6px; flex-wrap:wrap;">
                                    <a asp-controller="Order" asp-action="Edit"
                                       asp-route-id="@order.OrderId"
                                       class="btn btn-primary btn-sm">
                                        ✏️ Düzenle
                                    </a>
                                    <a asp-controller="OrderDetail" asp-action="Receipt"
                                       asp-route-orderId="@order.OrderId"
                                       class="btn btn-secondary btn-sm">
                                        🧾 Fiş
                                    </a>
                                    <button class="btn btn-danger btn-sm"
                                            onclick="confirmDelete('@Url.Action("Delete", "Order", new { id = order.OrderId })')">
                                        🗑 Sil
                                    </button>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        }
    </div>
</div>
